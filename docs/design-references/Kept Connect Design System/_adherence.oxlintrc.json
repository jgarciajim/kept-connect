{
  "plugins": [
    "react",
    "import"
  ],
  "rules": {
    "react/forbid-elements": [
      "warn",
      {
        "forbid": []
      }
    ],
    "no-restricted-imports": [
      "warn",
      {
        "patterns": [
          {
            "group": [
              "components/brand/**",
              "components/category/**",
              "components/core/**",
              "components/forms/**",
              "components/people/**",
              "components/trust/**",
              "ui_kits/provider/**",
              "ui_kits/requester/**"
            ],
            "message": "Import design-system components from 'index.js', not component internals."
          }
        ]
      }
    ],
    "no-restricted-syntax": [
      "warn",
      {
        "selector": "Literal[value=/#[0-9a-fA-F]{3,8}\\b/]",
        "message": "Raw hex color — use a design-system color token via var()."
      },
      {
        "selector": "Literal[value=/\\b\\d+px\\b/]",
        "message": "Raw px value — use a design-system spacing token via var()."
      },
      {
        "selector": "Literal[value=/font-family\\s*:\\s*(?!['\\\"]?(?:Fraunces|Hanken Grotesk))/i]",
        "message": "Font not provided by the design system. Available: Fraunces, Hanken Grotesk."
      },
      {
        "selector": "JSXOpeningElement[name.name='Avatar'] > JSXAttribute > JSXIdentifier[name!=/^(?:name|src|size|status|key|ref|className|style|children)$/]",
        "message": "<Avatar> doesn't accept that prop. Declared props: name, src, size, status."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute > JSXIdentifier[name!=/^(?:variant|size|fullWidth|disabled|icon|iconRight|children|key|ref|className|style|children)$/]",
        "message": "<Button> doesn't accept that prop. Declared props: variant, size, fullWidth, disabled, icon, iconRight, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:primary|secondary|outline|ghost|chrome-primary|chrome-ghost)$/]",
        "message": "<Button> variant must be one of 'primary' | 'secondary' | 'outline' | 'ghost' | 'chrome-primary' | 'chrome-ghost'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md|lg)$/]",
        "message": "<Button> size must be one of 'sm' | 'md' | 'lg'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Card'] > JSXAttribute > JSXIdentifier[name!=/^(?:tone|ribbon|padding|radius|lift|children|key|ref|className|style|children)$/]",
        "message": "<Card> doesn't accept that prop. Declared props: tone, ribbon, padding, radius, lift, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='Card'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:paper|moment|canvas|chrome)$/]",
        "message": "<Card> tone must be one of 'paper' | 'moment' | 'canvas' | 'chrome'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Card'] > JSXAttribute[name.name='ribbon'] > Literal[value!=/^(?:sameday|urgent|emerald)$/]",
        "message": "<Card> ribbon must be one of 'sameday' | 'urgent' | 'emerald'."
      },
      {
        "selector": "JSXOpeningElement[name.name='CategoryIcon'] > JSXAttribute > JSXIdentifier[name!=/^(?:category|size|dark|chip|key|ref|className|style|children)$/]",
        "message": "<CategoryIcon> doesn't accept that prop. Declared props: category, size, dark, chip."
      },
      {
        "selector": "JSXOpeningElement[name.name='Input'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|hint|multiline|rows|prefix|align|tabular|disabled|key|ref|className|style|children)$/]",
        "message": "<Input> doesn't accept that prop. Declared props: label, hint, multiline, rows, prefix, align, tabular, disabled."
      },
      {
        "selector": "JSXOpeningElement[name.name='Input'] > JSXAttribute[name.name='align'] > Literal[value!=/^(?:left|right)$/]",
        "message": "<Input> align must be one of 'left' | 'right'."
      },
      {
        "selector": "JSXOpeningElement[name.name='KeptConnectLogo'] > JSXAttribute > JSXIdentifier[name!=/^(?:treatment|variant|size|orientation|className|style|key|ref|className|style|children)$/]",
        "message": "<KeptConnectLogo> doesn't accept that prop. Declared props: treatment, variant, size, orientation, className, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='KeptConnectLogo'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:mark|lockup)$/]",
        "message": "<KeptConnectLogo> variant must be one of 'mark' | 'lockup'."
      },
      {
        "selector": "JSXOpeningElement[name.name='KeptConnectLogo'] > JSXAttribute[name.name='orientation'] > Literal[value!=/^(?:horizontal|stacked)$/]",
        "message": "<KeptConnectLogo> orientation must be one of 'horizontal' | 'stacked'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Tag'] > JSXAttribute > JSXIdentifier[name!=/^(?:variant|status|icon|children|key|ref|className|style|children)$/]",
        "message": "<Tag> doesn't accept that prop. Declared props: variant, status, icon, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='Tag'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:default|trade|status)$/]",
        "message": "<Tag> variant must be one of 'default' | 'trade' | 'status'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Tag'] > JSXAttribute[name.name='status'] > Literal[value!=/^(?:live|verified|neutral)$/]",
        "message": "<Tag> status must be one of 'live' | 'verified' | 'neutral'."
      },
      {
        "selector": "JSXOpeningElement[name.name='VerifiedBadge'] > JSXAttribute > JSXIdentifier[name!=/^(?:size|label|key|ref|className|style|children)$/]",
        "message": "<VerifiedBadge> doesn't accept that prop. Declared props: size, label."
      }
    ]
  },
  "overrides": [
    {
      "files": [
        "**/index.js"
      ],
      "rules": {
        "no-restricted-imports": "off"
      }
    }
  ],
